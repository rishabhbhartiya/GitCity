{
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "routes": [
        {
            "src": "/api/contributions/([a-zA-Z0-9_-]+)",
            "dest": "/api/contributions/$1"
        },
        {
            "src": "/api/og/([a-zA-Z0-9_-]+)",
            "dest": "/api/og/$1"
        },
        {
            "src": "/([a-zA-Z0-9_-]+)\\.svg$",
            "dest": "/api/og/$1"
        },
        {
            "src": "/([a-zA-Z0-9_-]+)$",
            "dest": "/?username=$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}