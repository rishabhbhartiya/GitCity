{
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "redirects": [
        {
            "source": "/:username.svg",
            "destination": "/api/og/:username",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/:username",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}