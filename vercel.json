{
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/story",
            "destination": "/story.html"
        },
        {
            "source": "/comparison",
            "destination": "/comparison.html"
        },
        {
            "source": "/:username/simulation",
            "destination": "/index.html"
        },
        {
            "source": "/:username/isometric",
            "destination": "/index.html"
        },
        {
            "source": "/:username/heatmap",
            "destination": "/index.html"
        },
        {
            "source": "/:username",
            "destination": "/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}